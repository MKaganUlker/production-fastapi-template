APP_APP_NAME=Production FastAPI Template
APP_APP_VERSION=0.2.0
APP_ENVIRONMENT=local
APP_DEBUG=false
APP_API_V1_PREFIX=/api/v1

APP_DATABASE_URL=postgresql+psycopg://fastapi:fastapi@localhost:5432/fastapi
APP_DATABASE_ECHO=false
APP_DATABASE_POOL_SIZE=5
APP_DATABASE_MAX_OVERFLOW=10
APP_DATABASE_POOL_TIMEOUT=30

POSTGRES_DB=fastapi
POSTGRES_USER=fastapi
POSTGRES_PASSWORD=fastapi